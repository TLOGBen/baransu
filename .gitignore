# --- everything-cli / Claude Code pipeline state ---
# Transient handoff artifacts, flow-state, health pulses.
.agent-workspace/

# Archived session work files (baransu /ship output — local only).
.claude/archived/

# Transient baransu workspace dirs — local only, archived by /ship into .claude/archived/.
.claude/dev/
.claude/think/

# self-healing harness telemetry — local only
# Directory persists by virtue of telemetry being written into it; no .gitkeep needed.
.claude/harness/

# Skill eval / optimization workspaces (transient, local only).
eval-workspace/

# /design preset output — design-cores/ is meant to land in CONSUMER projects,
# not in baransu source repo. The canonical skeletons live in
# plugins/baransu/skills/design/references/cores/.
/design-cores/

# Session telemetry written by the everything-cli harness.
# knowledge/solutions/ and other curated content under knowledge/ stays tracked.
knowledge/skill-telemetry.jsonl
knowledge/**/*.telemetry.jsonl

# Plugin cache / local install scratch (if a dev ever symlinks here).
.claude/plugins/cache/

# Runtime lock files written by ScheduleWakeup / /loop.
.claude/scheduled_tasks.lock

# Per-skill eval + optimization workspaces (transient artifacts from skill-creator).
plugins/*/skills/*-workspace/

# Per-user Claude Code settings — .claude/settings.json stays shared, only .local is ignored.
.claude/settings.local.json
.claude/**/settings.local.json

# --- Secrets ---
.env
.env.*
!.env.example

# --- OS cruft ---
.DS_Store
Thumbs.db
desktop.ini

# --- Editor / IDE ---
.idea/
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
*.swp
*.swo
*~

# --- Python ---
__pycache__/
*.pyc
*.pyo

# --- Future toolchains (safe to keep pre-emptively) ---
node_modules/
dist/
build/
*.log
.cache/
.tmp/
